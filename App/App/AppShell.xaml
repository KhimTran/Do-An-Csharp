<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:App.Services"
    xmlns:views="clr-namespace:App.Views">

    <TabBar>
        <ShellContent
            x:Name="ListTab"
            Title="{Binding [Shell_List], Source={x:Static services:LocalizationResourceManager.Instance}}"
            Route="list"
            ContentTemplate="{DataTemplate views:PoiListPage}" />

        <ShellContent
            x:Name="MapTab"
            Title="{Binding [Shell_Map], Source={x:Static services:LocalizationResourceManager.Instance}}"
            Route="map"
            ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent
            Title="{Binding [Shell_QR], Source={x:Static services:LocalizationResourceManager.Instance}}"
            ContentTemplate="{DataTemplate views:QrScanPage}" />

        <ShellContent
            Title="{Binding [Shell_History], Source={x:Static services:LocalizationResourceManager.Instance}}"
            ContentTemplate="{DataTemplate views:HistoryPage}" />

        <ShellContent
            Title="{Binding [Shell_Settings], Source={x:Static services:LocalizationResourceManager.Instance}}"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>
