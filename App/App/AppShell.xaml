<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="App.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:App.Views">

    <TabBar>
        <ShellContent
            Title="Danh sách"
            ContentTemplate="{DataTemplate views:PoiListPage}" />

        <ShellContent
            Title="Bản đồ"
            ContentTemplate="{DataTemplate views:MapPage}" />

        <ShellContent
            Title="QR"
            ContentTemplate="{DataTemplate views:QrScanPage}" />

        <ShellContent
            Title="Lịch sử"
            ContentTemplate="{DataTemplate views:HistoryPage}" />

        <ShellContent
            Title="Cài đặt"
            ContentTemplate="{DataTemplate views:SettingsPage}" />
    </TabBar>
</Shell>
