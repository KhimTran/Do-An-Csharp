<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="App.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
    Title="Bản đồ Vĩnh Khánh">

    <Grid RowDefinitions="*,Auto">

        <maps:Map
            x:Name="BanDo"
            Grid.Row="0"
            MapType="Street"
            IsShowingUser="True"
            Loaded="BanDo_Loaded" />

        <Frame
            Grid.Row="1"
            IsVisible="{Binding CoPoiGanNhat}"
            Padding="15"
            Margin="10"
            CornerRadius="15">
            <VerticalStackLayout Spacing="5">
                <Label
                    Text="📍 Bạn đang gần:"
                    FontSize="12"
                    TextColor="Gray" />
                <Label
                    Text="{Binding TenPoiGanNhat}"
                    FontSize="16"
                    FontAttributes="Bold" />
                <Label
                    Text="{Binding KhoangCachGanNhat, StringFormat='Cách {0:F0} mét'}"
                    FontSize="13"
                    TextColor="DodgerBlue" />
            </VerticalStackLayout>
        </Frame>

    </Grid>
</ContentPage>