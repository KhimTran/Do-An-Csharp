<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="App.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
    xmlns:services="clr-namespace:App.Services"
    Title="{Binding [MapPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <Grid RowDefinitions="*,Auto">
        <maps:Map x:Name="BanDo" Grid.Row="0" IsShowingUser="False" />

        <Grid x:Name="PoiPopupOverlay" Grid.Row="0" BackgroundColor="#66000000" IsVisible="False" Padding="20">
            <Frame
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="340"
                MaximumWidthRequest="420"
                MaximumHeightRequest="460"
                Padding="16"
                CornerRadius="8"
                BackgroundColor="White">
                <VerticalStackLayout Spacing="10">
                    <Label x:Name="PoiPopupTitle" FontSize="24" FontAttributes="Bold" TextColor="#1E1E1E" />
                    <Image x:Name="PoiPopupImage" IsVisible="False" Aspect="AspectFill" HeightRequest="170" />
                    <ScrollView MaximumHeightRequest="180">
                        <Label x:Name="PoiPopupDescription" FontSize="14" TextColor="#444444" LineBreakMode="WordWrap" />
                    </ScrollView>

                    <Grid ColumnDefinitions="*,Auto,Auto" Margin="0,8,0,0">
                        <Label />
                        <Button Grid.Column="1" Text="Đóng" Clicked="DongPopup_Clicked" />
                        <Button Grid.Column="2" Margin="8,0,0,0" Text="Tracking" Clicked="TrackingPopup_Clicked" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
        </Grid>

        <Frame
            Grid.Row="0"
            Margin="12"
            Padding="10,8"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            BackgroundColor="#CCFFFFFF"
            BorderColor="#22000000"
            CornerRadius="10">
            <VerticalStackLayout Spacing="2">
                <Label Text="{Binding [MapPage_LegendTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" FontAttributes="Bold" FontSize="12" />
                <Label Text="{Binding [MapPage_LegendUser], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" />
                <Label Text="{Binding [MapPage_LegendPoi], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" />
                <Label Text="{Binding [MapPage_LegendNearest], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" />
                <Label Text="{Binding [MapPage_LegendRoute], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="12" />
            </VerticalStackLayout>
        </Frame>

        <Frame Grid.Row="1" Margin="12" Padding="12">
            <VerticalStackLayout Spacing="6">
                <Label Text="{Binding [MapPage_NearestRoute], Source={x:Static services:LocalizationResourceManager.Instance}}" FontAttributes="Bold" />
                <Label Text="{Binding TenPoiGanNhat}" />
                <Label Text="{Binding KhoangCachGanNhat, StringFormat='{}{0:F0} m'}" />
            </VerticalStackLayout>
        </Frame>
    </Grid>
</ContentPage>
