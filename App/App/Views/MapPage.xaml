<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="App.Views.MapPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:App.Services"
    Title="{Binding [MapPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <Grid RowDefinitions="*,Auto">
        <WebView
            x:Name="BanDoWebView"
            Grid.Row="0"
            Navigating="BanDoWebView_Navigating" />

        <Grid
            Grid.Row="0"
            BackgroundColor="#66000000"
            IsVisible="{Binding HienThiPopupPoi}"
            Padding="20"
            ZIndex="20">
            <Border
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="340"
                MaximumWidthRequest="420"
                MaximumHeightRequest="460"
                Padding="16,14"
                BackgroundColor="White"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12">
                <Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="12">
                    <Label
                        Grid.Row="0"
                        FontSize="20"
                        FontAttributes="Bold"
                        Text="{Binding TieuDePopupPoi}"
                        TextColor="#1E1E1E" />

                    <Image
                        Grid.Row="1"
                        Aspect="AspectFill"
                        HeightRequest="170"
                        IsVisible="{Binding CoAnhPopupPoi}"
                        Source="{Binding UrlAnhPopupPoi}" />

                    <ScrollView Grid.Row="2" HeightRequest="170">
                        <Label
                            Margin="2,0"
                            CharacterSpacing="0.1"
                            FontSize="13"
                            LineBreakMode="WordWrap"
                            LineHeight="1.4"
                            Text="{Binding MoTaPopupPoi}"
                            TextColor="#3F4552" />
                    </ScrollView>

                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto,Auto" Margin="0,10,0,0">
                        <Label />
                        <Button
                            Grid.Column="1"
                            Clicked="DongPopup_Clicked"
                            FontSize="15"
                            Padding="18,10"
                            Text="{Binding [Common_Close], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                        <Button
                            Grid.Column="2"
                            Margin="8,0,0,0"
                            Clicked="TrackingPopup_Clicked"
                            FontSize="15"
                            Padding="18,10"
                            Text="{Binding [MapPage_Track], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Border
            Grid.Row="0"
            Margin="8"
            Padding="7,5"
            HorizontalOptions="Start"
            VerticalOptions="Start"
            BackgroundColor="#99FFFFFF"
            Stroke="#1A000000"
            StrokeShape="RoundRectangle 8"
            ZIndex="5">
            <VerticalStackLayout Spacing="1">
                <Label
                    FontAttributes="Bold"
                    FontSize="10"
                    Text="{Binding [MapPage_LegendTitle], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                <Label
                    FontSize="10"
                    Text="{Binding [MapPage_LegendUser], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                <Label
                    FontSize="10"
                    Text="{Binding [MapPage_LegendPoi], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                <Label
                    FontSize="10"
                    Text="{Binding [MapPage_LegendNearest], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                <Label
                    FontSize="10"
                    Text="{Binding [MapPage_LegendRoute], Source={x:Static services:LocalizationResourceManager.Instance}}" />
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="1"
                Margin="12"
                Padding="12"
                StrokeThickness="0"
                StrokeShape="RoundRectangle 12"
                ZIndex="5">
            <VerticalStackLayout Spacing="6">
                <Label
                    FontAttributes="Bold"
                    Text="{Binding [MapPage_NearestRoute], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                <Label Text="{Binding TenPoiGanNhat}" />
                <Label Text="{Binding KhoangCachGanNhat, StringFormat='{}{0:F0} m'}" />
                <Label FontSize="12" Text="{Binding TrangThaiPhat}" TextColor="#1F5C99" />
                <Label FontSize="12" Text="{Binding TrangThaiGps}" TextColor="#52606D" />
                <Label FontSize="12" Text="{Binding ThongBaoBanDo}" TextColor="#52606D" />
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
