<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             x:DataType="vm:QrScanViewModel"
             x:Class="App.Views.QrScanPage"
             Title="Quét mã QR">

    <Grid RowDefinitions="*,Auto,Auto">

        <Border Grid.Row="0"
                Margin="20"
                StrokeShape="RoundRectangle 12"
                BackgroundColor="#1a1a2e">
            <VerticalStackLayout VerticalOptions="Center" Spacing="12">
                <Label Text="📷"
                       FontSize="60"
                       HorizontalOptions="Center" />
                <Label Text="Camera QR tạm thời đang ở chế độ demo"
                       FontSize="18"
                       TextColor="White"
                       HorizontalOptions="Center" />
                <Label Text="Dùng nút bên dưới để test POI"
                       FontSize="14"
                       TextColor="LightGray"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Border>

        <Label Grid.Row="1"
               Text="{Binding ThongBao}"
               FontSize="16"
               HorizontalOptions="Center"
               Margin="10" />

        <VerticalStackLayout Grid.Row="2" Spacing="10" Margin="20">
            <Button Text="Test: Quét POI số 1"
                    Command="{Binding XuLyQrCommand}"
                    CommandParameter="1"
                    BackgroundColor="#1F5C99"
                    TextColor="White" />

            <Button Text="Test: Quét POI số 2"
                    Command="{Binding XuLyQrCommand}"
                    CommandParameter="2"
                    BackgroundColor="#1F5C99"
                    TextColor="White" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>