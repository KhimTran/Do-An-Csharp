<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             x:DataType="vm:QrScanViewModel"
             x:Class="App.Views.QrScanPage"
             Title="Quét mã QR">

    <Grid RowDefinitions="Auto,Auto,*,Auto"
          Padding="14,10,14,14"
          RowSpacing="8">
        <Label Grid.Row="0"
               Text="Quét mã QR"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               Margin="0,6,0,0" />

        <Label Grid.Row="1"
               Text="Quét mã QR của quán để nghe thuyết minh"
               FontSize="15"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               Margin="8,0,8,0" />

        <Border Grid.Row="2"
                StrokeShape="RoundRectangle 16"
                VerticalOptions="Fill"
                MinimumHeightRequest="420"
                Margin="0,0,0,4">
            <Grid>
                <Grid x:Name="CameraHost" />

                <Border x:Name="CameraFallbackOverlay"
                        StrokeShape="RoundRectangle 14"
                        BackgroundColor="#66000000"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        Margin="12"
                        IsVisible="False">
                    <VerticalStackLayout Padding="14"
                                         Spacing="10"
                                         VerticalOptions="Center">
                        <Label Text="Camera chưa sẵn sàng trên thiết bị này."
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                        <Label x:Name="CameraDebugHintLabel"
                               Text="Nếu đang dùng emulator, hãy thử trên điện thoại thật để quét QR."
                               TextColor="White"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <Label Grid.Row="3"
               Text="{Binding TrangThaiQuet}"
               FontSize="15"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               LineBreakMode="WordWrap"
               Margin="8,0,8,0" />
    </Grid>
</ContentPage>
