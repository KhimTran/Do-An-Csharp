<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             xmlns:services="clr-namespace:App.Services"
             x:DataType="vm:QrScanViewModel"
             x:Class="App.Views.QrScanPage"
             Title="{Binding [QrPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <Grid RowDefinitions="*,Auto,Auto" Padding="12">

        <Border Grid.Row="0" StrokeShape="RoundRectangle 12">
            <Grid>
                <zxing:CameraBarcodeReaderView x:Name="QrCamera"
                                               IsDetecting="{Binding DangQuet}"
                                               BarcodesDetected="BarcodeReader_BarcodesDetected" />

                <Border StrokeShape="RoundRectangle 10" BackgroundColor="#66000000"
                        HorizontalOptions="Center" VerticalOptions="End" Margin="12">
                    <Label Text="{Binding [QrPage_Hint], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           TextColor="White" Padding="10,6" />
                </Border>
            </Grid>
        </Border>

        <Label Grid.Row="1"
               Text="{Binding ThongBao}"
               FontSize="16"
               HorizontalOptions="Center"
               Margin="10" />

        <Button Grid.Row="2"
                Text="{Binding [QrPage_TestButton], Source={x:Static services:LocalizationResourceManager.Instance}}"
                Command="{Binding XuLyQrCommand}"
                CommandParameter="1"
                Margin="10"
                BackgroundColor="#1F5C99"
                TextColor="White" />
    </Grid>
</ContentPage>
