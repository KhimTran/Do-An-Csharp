<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:models="clr-namespace:App.Models"
             xmlns:services="clr-namespace:App.Services"
             x:DataType="vm:PoiListViewModel"
             x:Class="App.Views.PoiListPage"
             Title="{Binding [PoiPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}">
    <Grid RowDefinitions="Auto,*,Auto">
        <Label Grid.Row="0" Text="{Binding ThongBao}"
               HorizontalOptions="Center" Margin="10" TextColor="Gray" />
        <ActivityIndicator Grid.Row="1"
                           IsRunning="{Binding DangTai}"
                           IsVisible="{Binding DangTai}" />
        <CollectionView Grid.Row="1" ItemsSource="{Binding DanhSachPoi}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:PoiModel">
                    <Border Padding="12" Margin="10,5" StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding Ten}" FontSize="16" FontAttributes="Bold" />
                            <Label Text="{Binding MoTa_Vi}" FontSize="12" TextColor="Gray" />
                            <Label Text="{Binding BanKinh, StringFormat='{}{0} m'}"
                                   FontSize="11" TextColor="DodgerBlue" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <Button Grid.Row="2"
                Text="{Binding [PoiPage_LoadButton], Source={x:Static services:LocalizationResourceManager.Instance}}"
                Command="{Binding TaiDanhSachPoiCommand}"
                Margin="20" BackgroundColor="#1F5C99" TextColor="White" />
    </Grid>
</ContentPage>
