<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:App.Services"
    Title="{Binding [SettingsPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Label Text="{Binding [SettingsPage_Header], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   FontSize="22"
                   FontAttributes="Bold" />

            <Frame Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding [SettingsPage_Language], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontAttributes="Bold" />
                    <Picker x:Name="NgonNguPicker"
                            Title="{Binding [SettingsPage_LanguagePicker], Source={x:Static services:LocalizationResourceManager.Instance}}">
                        <Picker.Items>
                            <x:String>Tiếng Việt</x:String>
                            <x:String>English</x:String>
                            <x:String>中文</x:String>
                        </Picker.Items>
                    </Picker>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding [SettingsPage_Radius], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontAttributes="Bold" />
                    <Label x:Name="BanKinhLabel"
                           Text="50 m" />
                    <Slider x:Name="BanKinhSlider"
                            Minimum="20"
                            Maximum="200"
                            Value="50"
                            ValueChanged="BanKinhSlider_ValueChanged" />
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16">
                <VerticalStackLayout Spacing="10">
                    <Label Text="{Binding [SettingsPage_Offline], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontAttributes="Bold" />
                    <HorizontalStackLayout Spacing="12">
                        <Switch x:Name="OfflineSwitch" />
                        <Label Text="{Binding [SettingsPage_OfflineHint], Source={x:Static services:LocalizationResourceManager.Instance}}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Frame Padding="16">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding [SettingsPage_ApiBaseUrl], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontAttributes="Bold" />
                    <Entry x:Name="ApiBaseUrlEntry"
                           Placeholder="{Binding [SettingsPage_ApiBaseUrlHint], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           Keyboard="Url"
                           ClearButtonVisibility="WhileEditing" />
                </VerticalStackLayout>
            </Frame>

            <Label Text="{Binding [SettingsPage_Info], Source={x:Static services:LocalizationResourceManager.Instance}}"
                   FontSize="12"
                   TextColor="Gray" />

            <Button Text="{Binding [SettingsPage_Save], Source={x:Static services:LocalizationResourceManager.Instance}}"
                    Clicked="LuuButton_Clicked" />

            <Button Text="{Binding [SettingsPage_Reset], Source={x:Static services:LocalizationResourceManager.Instance}}"
                    Clicked="MacDinhButton_Clicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
