<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:services="clr-namespace:App.Services"
    Title="{Binding [SettingsPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}">

    <ContentPage.Resources>
        <LinearGradientBrush x:Key="SaveButtonBrush" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#5B31D6" Offset="0.0" />
            <GradientStop Color="#6C3DFF" Offset="1.0" />
        </LinearGradientBrush>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="BackgroundColor" Value="White" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="Stroke" Value="#EEE9FA" />
            <Setter Property="StrokeThickness" Value="1" />
            <Setter Property="StrokeShape" Value="RoundRectangle 20" />
            <Setter Property="Shadow">
                <Setter.Value>
                    <Shadow Brush="#18000000" Offset="0,6" Radius="18" Opacity="0.18" />
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="Label">
            <Setter Property="FontFamily" Value="OpenSansSemibold" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="TextColor" Value="#1E2454" />
        </Style>

        <Style x:Key="SectionSubtitleStyle" TargetType="Label">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="TextColor" Value="#667085" />
            <Setter Property="LineBreakMode" Value="WordWrap" />
        </Style>

        <Style x:Key="IconBadgeStyle" TargetType="Border">
            <Setter Property="WidthRequest" Value="64" />
            <Setter Property="HeightRequest" Value="64" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BackgroundColor" Value="#F1ECFF" />
            <Setter Property="StrokeThickness" Value="0" />
            <Setter Property="StrokeShape" Value="RoundRectangle 32" />
            <Setter Property="HorizontalOptions" Value="Start" />
            <Setter Property="VerticalOptions" Value="Start" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24,18,24,28" Spacing="0">

            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="14" Margin="0,8,0,24">
                <Border Grid.Column="0"
                        Style="{StaticResource IconBadgeStyle}"
                        BackgroundColor="#F3EEFF">
                    <Label Text="&#x2699;"
                           FontSize="36"
                           TextColor="#5B31D6"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding [SettingsPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontFamily="OpenSansSemibold"
                           FontSize="28"
                           TextColor="#101828" />
                    <Label Text="{Binding [SettingsPage_Subtitle], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="14"
                           TextColor="#667085" />
                </VerticalStackLayout>
            </Grid>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border Style="{StaticResource IconBadgeStyle}">
                        <Label Text="&#x1F310;"
                               FontSize="30"
                               TextColor="#5B31D6"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding [SettingsPage_Language], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                            <Label Style="{StaticResource SectionSubtitleStyle}"
                                   Text="{Binding [SettingsPage_LanguageDescription], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                        </VerticalStackLayout>

                        <Border Padding="16,8"
                                BackgroundColor="White"
                                Stroke="#D9DCE3"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 14">
                            <Picker x:Name="NgonNguPicker"
                                    Title="{Binding [SettingsPage_LanguagePicker], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                    <Border Style="{StaticResource IconBadgeStyle}">
                        <Label Text="&#x1F4CD;"
                               FontSize="30"
                               TextColor="#5B31D6"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="14">
                        <VerticalStackLayout Spacing="2">
                            <Label Style="{StaticResource SectionTitleStyle}"
                                   Text="{Binding [SettingsPage_Radius], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                            <Label Style="{StaticResource SectionSubtitleStyle}"
                                   Text="{Binding [SettingsPage_RadiusDescription], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Spacing="6">
                            <Label Text="{Binding [SettingsPage_RadiusValueLabel], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                   FontSize="15"
                                   TextColor="#344054" />
                            <Label x:Name="BanKinhLabel"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="16"
                                   TextColor="#5B31D6"
                                   Text="50m" />
                        </HorizontalStackLayout>

                        <Slider x:Name="BanKinhSlider"
                                Minimum="10"
                                Maximum="200"
                                Value="50"
                                ValueChanged="BanKinhSlider_ValueChanged" />

                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="12">
                            <Label Text="10m" FontSize="12" TextColor="#667085" />
                            <Label Grid.Column="1" HorizontalOptions="Center" Text="30m" FontSize="12" TextColor="#5B31D6" />
                            <Label Grid.Column="2" Text="100m" FontSize="12" TextColor="#667085" />
                            <Label Grid.Column="3" HorizontalOptions="End" Text="200m" FontSize="12" TextColor="#667085" />
                        </Grid>

                        <Border Padding="14"
                                BackgroundColor="#F4F0FF"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 14">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                                <Label Text="&#x2139;"
                                       FontSize="22"
                                       TextColor="#5B31D6"
                                       VerticalOptions="Start" />
                                <Label Grid.Column="1"
                                       Style="{StaticResource SectionSubtitleStyle}"
                                       Text="{Binding [SettingsPage_RadiusHint], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                       TextColor="#475467" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}">
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                    <Border Style="{StaticResource IconBadgeStyle}">
                        <Label Text="&#x1F4F6;"
                               FontSize="30"
                               TextColor="#5B31D6"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Style="{StaticResource SectionTitleStyle}"
                               Text="{Binding [SettingsPage_Offline], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                        <Label Style="{StaticResource SectionSubtitleStyle}"
                               Text="{Binding [SettingsPage_OfflineHint], Source={x:Static services:LocalizationResourceManager.Instance}}" />
                    </VerticalStackLayout>

                    <Switch x:Name="OfflineSwitch"
                            Grid.Column="2"
                            HorizontalOptions="End"
                            VerticalOptions="Center" />
                </Grid>
            </Border>

            <Button Text="{Binding [SettingsPage_Save], Source={x:Static services:LocalizationResourceManager.Instance}}"
                    Clicked="LuuButton_Clicked"
                    HeightRequest="56"
                    CornerRadius="18"
                    Margin="0,8,0,14"
                    FontFamily="OpenSansSemibold"
                    FontSize="17"
                    Background="{StaticResource SaveButtonBrush}" />

            <Button Text="{Binding [SettingsPage_Reset], Source={x:Static services:LocalizationResourceManager.Instance}}"
                    Clicked="MacDinhButton_Clicked"
                    HeightRequest="56"
                    CornerRadius="18"
                    FontFamily="OpenSansSemibold"
                    FontSize="17"
                    TextColor="#5B31D6"
                    BackgroundColor="White"
                    BorderColor="#6C3DFF"
                    BorderWidth="2" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
