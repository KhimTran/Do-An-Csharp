<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:services="clr-namespace:App.Services"
             x:Class="App.Views.HistoryPage"
             x:Name="PageRoot"
             x:DataType="vm:HistoryViewModel"
             Title="{Binding [HistoryPage_Title], Source={x:Static services:LocalizationResourceManager.Instance}}"
             BackgroundColor="#0B1020">

    <RefreshView Command="{Binding TaiDuLieuCommand}" IsRefreshing="{Binding DangTai}">
        <ScrollView>
            <VerticalStackLayout Padding="20,18,20,28" Spacing="20">
                <VerticalStackLayout Spacing="4">
                    <Label Text="{Binding [HistoryPage_Header], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="White" />
                    <Label Text="{Binding [HistoryPage_Subtitle], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="15"
                           TextColor="#B8B5D0" />
                </VerticalStackLayout>

                <Border Padding="0"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 24">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#6D3DDB" Offset="0.0" />
                            <GradientStop Color="#24164A" Offset="1.0" />
                        </LinearGradientBrush>
                    </Border.Background>
                    <VerticalStackLayout Spacing="0">
                        <Grid Padding="18" ColumnDefinitions="*,1,*,1,*" ColumnSpacing="14">
                            <VerticalStackLayout Grid.Column="0" Spacing="6" HorizontalOptions="Center">
                                <Label Text="&#x1F4CD;" FontSize="28" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding TongDiaDiemDaKhamPha}" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White" />
                                <Label Text="{Binding [HistoryPage_SummaryPlaces], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" HorizontalTextAlignment="Center" TextColor="#E4DAFF" />
                            </VerticalStackLayout>

                            <BoxView Grid.Column="1" WidthRequest="1" HorizontalOptions="Start" Color="#7D63D6" />
                            <VerticalStackLayout Grid.Column="2" Spacing="6" HorizontalOptions="Center">
                                <Label Text="&#x1F3A7;" FontSize="28" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding TongLuotNghe}" FontSize="28" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White" />
                                <Label Text="{Binding [HistoryPage_SummaryPlays], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" HorizontalTextAlignment="Center" TextColor="#E4DAFF" />
                            </VerticalStackLayout>

                            <BoxView Grid.Column="3" WidthRequest="1" HorizontalOptions="Start" Color="#7D63D6" />
                            <VerticalStackLayout Grid.Column="4" Spacing="6" HorizontalOptions="Center">
                                <Label Text="&#x2B50;" FontSize="28" HorizontalTextAlignment="Center" />
                                <Label Text="{Binding TenPoiNgheNhieuNhat}" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" TextColor="White" LineBreakMode="TailTruncation" MaxLines="2" />
                                <Label Text="{Binding [HistoryPage_SummaryFavorite], Source={x:Static services:LocalizationResourceManager.Instance}}" FontSize="13" HorizontalTextAlignment="Center" TextColor="#E4DAFF" />
                            </VerticalStackLayout>
                        </Grid>

                        <Border StrokeThickness="0" BackgroundColor="#191133" StrokeShape="RoundRectangle 0,0,24,24" Padding="18,14">
                            <Label Text="{Binding TomTatHanhTrinh}" FontSize="16" HorizontalTextAlignment="Center" TextColor="#F2EEFF" />
                        </Border>
                    </VerticalStackLayout>
                </Border>

                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding [HistoryPage_Top], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <CollectionView ItemsSource="{Binding TopPoi}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Border Stroke="#352F4A"
                                    BackgroundColor="#131827"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 18">
                                <Label Text="{Binding [HistoryPage_NoStats], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                       TextColor="#B8B5D0" />
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryTopPoiItemViewModel">
                                <Border Margin="0,0,0,10"
                                        Padding="16"
                                        Stroke="{Binding VienMau}"
                                        BackgroundColor="{Binding NenMau}"
                                        StrokeShape="RoundRectangle 20">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                        <Border StrokeThickness="0"
                                                BackgroundColor="{Binding NhanNenMau}"
                                                Padding="10,6"
                                                StrokeShape="RoundRectangle 999">
                                            <Label Text="{Binding NhanHang}"
                                                   FontAttributes="Bold"
                                                   FontSize="14"
                                                   TextColor="White" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                                            <Label Text="{Binding TenPoi}"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                            <Label Text="{Binding LuotNgheText}"
                                                   FontSize="15"
                                                   TextColor="#C7B9FF" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2"
                                               Text="&#x1F525;"
                                               FontSize="22"
                                               IsVisible="{Binding LaTop1}"
                                               VerticalTextAlignment="Start" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="12">
                    <Label Text="{Binding [HistoryPage_Recent], Source={x:Static services:LocalizationResourceManager.Instance}}"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="White" />

                    <CollectionView ItemsSource="{Binding LichSuGanDay}"
                                    SelectionMode="None">
                        <CollectionView.EmptyView>
                            <Border Stroke="#352F4A"
                                    BackgroundColor="#131827"
                                    Padding="16"
                                    StrokeShape="RoundRectangle 18">
                                <Label Text="{Binding [HistoryPage_NoPlayback], Source={x:Static services:LocalizationResourceManager.Instance}}"
                                       TextColor="#B8B5D0" />
                            </Border>
                        </CollectionView.EmptyView>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:HistoryRecentItemViewModel">
                                <Border Margin="0,0,0,12"
                                        Padding="14"
                                        Stroke="#2D344B"
                                        BackgroundColor="#131827"
                                        StrokeShape="RoundRectangle 22">
                                    <Grid ColumnDefinitions="54,*,Auto" ColumnSpacing="14">
                                        <Border StrokeThickness="0"
                                                HeightRequest="54"
                                                WidthRequest="54"
                                                BackgroundColor="{Binding MauDaiDien}"
                                                StrokeShape="RoundRectangle 18">
                                            <Label Text="{Binding ChuCaiDaiDien}"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                        </Border>

                                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                                            <Label Text="{Binding TenPoi}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="White" />
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="{Binding GioPhat}" FontSize="14" TextColor="#B8B5D0" />
                                                <Label Text="&#x2022;" FontSize="14" TextColor="#7C839A" />
                                                <Label Text="{Binding NguonHienThi}" FontSize="14" TextColor="#B8B5D0" />
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <Button Grid.Column="2"
                                                Text="{Binding Source={x:Static services:LocalizationResourceManager.Instance}, Path=[HistoryPage_ReplayButton]}"
                                                Command="{Binding Source={x:Reference PageRoot}, Path=BindingContext.NgheLaiCommand}"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#7C4DFF"
                                                TextColor="White"
                                                CornerRadius="18"
                                                Padding="14,10"
                                                FontAttributes="Bold"
                                                VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>
