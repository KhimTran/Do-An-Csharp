<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:App.ViewModels"
             xmlns:models="clr-namespace:App.Models"
             x:DataType="vm:HistoryViewModel"
             x:Class="App.Views.HistoryPage"
             Title="Lịch sử nghe">

    <VerticalStackLayout Padding="10">

        <!-- Tiêu đề -->
        <Label Text="{Binding ThongBao}"
               FontSize="16"
               HorizontalOptions="Center"
               TextColor="Gray" />

        <!-- Danh sách -->
        <CollectionView ItemsSource="{Binding LichSu}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LichSuPhatModel">

                    <Frame Margin="5"
                           Padding="10"
                           CornerRadius="10"
                           HasShadow="True">

                        <VerticalStackLayout Spacing="4">

                            <Label Text="{Binding TenPoi}"
                                   FontAttributes="Bold"
                                   FontSize="16" />

                            <Label Text="{Binding ThoiGianPhat, StringFormat='Thời gian: {0:dd/MM HH:mm}'}"
                                   FontSize="13" />

                            <Label Text="{Binding NgonNgu, StringFormat='Ngôn ngữ: {0}'}"
                                   FontSize="13" />

                            <Label Text="{Binding NguonKichHoat, StringFormat='Nguồn: {0}'}"
                                   FontSize="13"
                                   TextColor="DodgerBlue" />

                        </VerticalStackLayout>

                    </Frame>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <!-- Nút tải -->
        <Button Text="Tải lại"
                Command="{Binding TaiLichSuCommand}"
                Margin="10"
                BackgroundColor="#1F5C99"
                TextColor="White" />

    </VerticalStackLayout>

</ContentPage>