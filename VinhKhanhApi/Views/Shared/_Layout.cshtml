<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VK CMS</title>
    @RenderSection("Head", required: false)
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/cms.css" asp-append-version="true" />
</head>
<body class="cms-body">
    <div class="cms-shell">
        <aside class="cms-sidebar">
            <div class="brand">VK CMS</div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link" href="@Url.Action("Index", "Cms")">Quan ly POI</a>
                    <a class="nav-link" href="@Url.Action("Stats", "Cms")">Thong ke tong</a>
                    <a class="nav-link" href="@Url.Action("Monitoring", "Cms")">Monitoring</a>
                    <a class="nav-link" href="@Url.Action("Users", "Cms")">Tai khoan</a>
                }

                @if (User.IsInRole("Owner"))
                {
                    <a class="nav-link" href="@Url.Action("Dashboard", "Owner")">Quan cua toi</a>
                }

                <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:16px;">
                    @Html.AntiForgeryToken()
                    <button class="vk-btn secondary" type="submit">Dang xuat</button>
                </form>
            }
            else
            {
                <a class="nav-link" href="@Url.Action("Login", "Account")">Dang nhap</a>
            }
        </aside>

        <main class="cms-main">
            @RenderBody()
        </main>
    </div>
</body>
</html>
