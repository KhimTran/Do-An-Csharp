<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VK CMS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/cms.css" asp-append-version="true" />
</head>
<body class="cms-body">
    <div class="cms-shell">
        <aside class="cms-sidebar">
            <div class="brand">VK CMS</div>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
               href="@Url.Action("Index", "Cms")">Quản lý POI</a>
            <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Stats" ? "active" : "")"
               href="@Url.Action("Stats", "Cms")">Xem thống kê</a>
            <a class="nav-link" href="@Url.Action("GetAll", "Pois")" target="_blank">Xem API JSON</a>
        </aside>

        <main class="cms-main">
            @RenderBody()
        </main>
    </div>
</body>
</html>
