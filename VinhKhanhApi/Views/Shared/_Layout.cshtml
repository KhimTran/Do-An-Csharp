@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VK CMS</title>
    @RenderSection("Head", required: false)
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/cms.css" asp-append-version="true" />
</head>
<body class="cms-body">
    <div class="cms-shell">
        <aside class="cms-sidebar">
            <div class="brand">VK CMS</div>

            @if (User.Identity?.IsAuthenticated == true)
            {
                var currentRoleLabel = User.IsInRole("Admin")
                    ? "Quản trị viên"
                    : User.IsInRole("Owner")
                        ? "Chủ quán"
                        : null;

                @if (User.IsInRole("Admin"))
                {
                    <a class="nav-link @(currentController == "Cms" && currentAction == "Index" ? "active" : "")"
                       href="@Url.Action("Index", "Cms")">Quản lý POI</a>
                    <a class="nav-link @(currentController == "Cms" && currentAction == "Stats" ? "active" : "")"
                       href="@Url.Action("Stats", "Cms")">Thống kê tổng</a>
                    <a class="nav-link @(currentController == "Cms" && currentAction == "QrCodes" ? "active" : "")"
                       href="@Url.Action("QrCodes", "Cms")">Mã QR</a>
                    <a class="nav-link @(currentController == "Cms" && currentAction == "Monitoring" ? "active" : "")"
                       href="@Url.Action("Monitoring", "Cms")">Monitoring</a>
                    <a class="nav-link @(currentController == "Cms" && currentAction == "Users" ? "active" : "")"
                       href="@Url.Action("Users", "Cms")">Tài khoản</a>
                }

                @if (User.IsInRole("Owner"))
                {
                    <a class="nav-link @(currentController == "Owner" && currentAction == "Dashboard" ? "active" : "")"
                       href="@Url.Action("Dashboard", "Owner")">Quán của tôi</a>
                    <a class="nav-link @(currentController == "Owner" && currentAction == "Stats" ? "active" : "")"
                       href="@Url.Action("Stats", "Owner")">Thống kê quán</a>
                }

                <div class="sidebar-user">
                    <div class="sidebar-user-label">Đang đăng nhập:</div>
                    <div class="sidebar-user-name">@User.Identity?.Name</div>
                    @if (!string.IsNullOrWhiteSpace(currentRoleLabel))
                    {
                        <div class="sidebar-user-role">Vai trò: @currentRoleLabel</div>
                    }
                </div>

                <form asp-controller="Account" asp-action="Logout" method="post" style="margin-top:16px;">
                    @Html.AntiForgeryToken()
                    <button class="vk-btn secondary" type="submit">Đăng xuất</button>
                </form>
            }
            else
            {
                <a class="nav-link @(currentController == "Account" && currentAction == "Login" ? "active" : "")"
                   href="@Url.Action("Login", "Account")">Đăng nhập</a>
            }
        </aside>

        <main class="cms-main">
            @RenderBody()
        </main>
    </div>
</body>
</html>

