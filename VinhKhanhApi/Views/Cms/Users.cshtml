@using System.Security.Claims
@model List<VinhKhanhApi.Models.UserAccountModel>
@{
    ViewData["Title"] = "Quản lý tài khoản";
    var pois = ViewData["Pois"] as List<VinhKhanhApi.Models.PoiModel> ?? new();
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    var stt = 1;
}

<h1 class="page-title">Tài khoản hệ thống</h1>
@if (TempData["ok"] != null) { <div class="alert alert-success">@TempData["ok"]</div> }
@if (TempData["err"] != null) { <div class="alert alert-danger">@TempData["err"]</div> }

<div class="vk-form mb-4">
    <h4>Tạo tài khoản quản trị viên</h4>
    <form asp-action="CreateAdminAccount" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <div class="col-md-5"><input name="username" class="form-control" placeholder="Tên đăng nhập" /></div>
        <div class="col-md-5"><input name="password" class="form-control" placeholder="Mật khẩu" type="password" /></div>
        <div class="col-md-2"><button class="vk-btn primary w-100" type="submit">Tạo quản trị viên</button></div>
    </form>
</div>

<div class="vk-form mb-4">
    <h4>Tạo tài khoản chủ quán</h4>
    <form asp-action="CreateOwnerAccount" method="post" class="row g-3">
        @Html.AntiForgeryToken()
        <div class="col-md-4"><input name="username" class="form-control" placeholder="Tên đăng nhập" /></div>
        <div class="col-md-3"><input name="password" class="form-control" placeholder="Mật khẩu" type="password" /></div>
        <div class="col-md-3">
            <select name="poiId" class="form-control">
                @foreach (var poi in pois)
                {
                    <option value="@poi.Id">@poi.Ten</option>
                }
            </select>
        </div>
        <div class="col-md-2"><button class="vk-btn primary w-100" type="submit">Tạo tài khoản chủ quán</button></div>
    </form>
</div>

<div class="vk-table-wrap">
    <table class="vk-table">
        <thead>
            <tr>
                <th>STT</th>
                <th>Username</th>
                <th>Vai trò</th>
                <th>Quán được quản lý</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model)
            {
                var poiName = u.PoiId.HasValue
                    ? pois.FirstOrDefault(p => p.Id == u.PoiId.Value)?.Ten ?? u.PoiId.Value.ToString()
                    : "Toàn hệ thống";
                var roleName = u.Role switch
                {
                    "Admin" => "Quản trị viên",
                    "Owner" => "Chủ quán",
                    _ => u.Role
                };
                var isCurrentUser = currentUserId == u.Id.ToString();
                var isDefaultAdmin = string.Equals(u.Username, "admin", StringComparison.OrdinalIgnoreCase);

                <tr>
                    <td>@stt</td>
                    <td>@u.Username</td>
                    <td>@roleName</td>
                    <td>@poiName</td>
                    <td>
                        @if (u.IsActive)
                        {
                            <span class="badge-pill badge-approved">● Đang hoạt động</span>
                        }
                        else
                        {
                            <span class="badge-pill badge-rejected">● Bị khóa</span>
                        }
                    </td>
                    <td class="d-flex gap-2 flex-wrap">
                        @if (isCurrentUser)
                        {
                            <span>Tài khoản hiện tại</span>
                        }
                        else
                        {
                            <form asp-action="ToggleUserLock" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@u.Id" />
                                <button class="vk-btn @(u.IsActive ? "warning" : "primary")" type="submit">
                                    @(u.IsActive ? "Khóa" : "Mở khóa")
                                </button>
                            </form>

                            @if (!isDefaultAdmin)
                            {
                                <form asp-action="DeleteUser" method="post" onsubmit="return confirm('Xóa tài khoản này?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button class="vk-btn danger" type="submit">Xóa</button>
                                </form>
                            }
                        }
                    </td>
                </tr>

                stt++;
            }
        </tbody>
    </table>
</div>

