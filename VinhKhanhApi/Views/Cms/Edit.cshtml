@model VinhKhanhApi.ViewModels.CmsPoiFormViewModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Tạo POI" : "Sửa POI";
}

<h1 class="page-title">@ViewData["Title"]</h1>

<form asp-action="Edit" asp-controller="Cms" method="post" enctype="multipart/form-data" class="vk-form">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />

    <div class="mb-3"><label>Tên</label><input asp-for="Ten" class="form-control" /></div>
    <div class="mb-3"><label>Mô tả VI</label><textarea asp-for="MoTa_Vi" class="form-control"></textarea></div>
    <div class="mb-3"><label>Mô tả EN</label><textarea asp-for="MoTa_En" class="form-control"></textarea></div>
    <div class="mb-3"><label>Mô tả ZH</label><textarea asp-for="MoTa_Zh" class="form-control"></textarea></div>

    <div class="row">
        <div class="col-md-6 mb-3"><label>Lat</label><input asp-for="Lat" class="form-control" /></div>
        <div class="col-md-6 mb-3"><label>Lng</label><input asp-for="Lng" class="form-control" /></div>
        <div class="col-md-6 mb-3"><label>Bán kính geofence (m)</label><input asp-for="BanKinh" class="form-control" /></div>
        <div class="col-md-6 mb-3"><label>Ưu tiên</label><input asp-for="UuTien" class="form-control" /></div>
    </div>

    <h4 class="mt-4">Nội dung QR & Audio/TTS (Admin)</h4>
    <div class="row">
        <div class="col-md-8 mb-3"><label>Nội dung QR</label><input asp-for="QrCodeNoiDung" class="form-control" placeholder="poi:123" /></div>
        <div class="col-md-4 mb-3"><label>Giọng TTS mặc định</label><input asp-for="TtsVoiceCode" class="form-control" placeholder="vi-VN" /></div>
    </div>

    <hr />
    <div class="mb-3">
        <label>Audio VI (.mp3)</label>
        <input asp-for="AudioVi" type="file" class="form-control" />
        <small class="muted">@Model.TenFileAudio_Vi</small>
    </div>
    <div class="mb-3">
        <label>Audio EN (.mp3)</label>
        <input asp-for="AudioEn" type="file" class="form-control" />
        <small class="muted">@Model.TenFileAudio_En</small>
    </div>
    <div class="mb-3">
        <label>Audio ZH (.mp3)</label>
        <input asp-for="AudioZh" type="file" class="form-control" />
        <small class="muted">@Model.TenFileAudio_Zh</small>
    </div>

    <button type="submit" class="vk-btn primary">Lưu</button>
    <a class="vk-btn secondary" href="@Url.Action("Index", "Cms")">Quay lại</a>
</form>
