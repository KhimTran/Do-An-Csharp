@model VinhKhanhApi.ViewModels.OwnerShopViewModel
@{
    ViewData["Title"] = "Cổng Chủ quán";
}

<h1 class="page-title">Chủ quán - @Model.Ten</h1>
@if (TempData["ok"] != null)
{
    <div class="alert alert-success">@TempData["ok"]</div>
}

<form method="post" asp-action="Dashboard" enctype="multipart/form-data" class="vk-form">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="PoiId" />
    <div class="mb-3"><label>Mô tả VI</label><textarea asp-for="MoTa_Vi" class="form-control" rows="4"></textarea></div>
    <div class="mb-3"><label>Mô tả EN</label><textarea asp-for="MoTa_En" class="form-control" rows="4"></textarea></div>
    <div class="mb-3"><label>Mô tả ZH</label><textarea asp-for="MoTa_Zh" class="form-control" rows="4"></textarea></div>
    <div class="mb-3">
        <label>Ảnh minh họa POI</label>
        <input asp-for="AnhMinhHoa" type="file" class="form-control" accept="image/*" />
        @if (!string.IsNullOrWhiteSpace(Model.TenFileAnhMinhHoa))
        {
            <div class="mt-2">
                <img src="~/images/poi/@Model.TenFileAnhMinhHoa" alt="Ảnh minh họa @Model.Ten" class="poi-preview-image" />
            </div>
            <small class="muted">@Model.TenFileAnhMinhHoa</small>
        }
    </div>

    <div class="mb-3">
        <label>Audio VI (.mp3)</label>
        <input asp-for="AudioVi" type="file" class="form-control" accept=".mp3,audio/mpeg" />
        <small class="muted">@Model.TenFileAudio_Vi</small>
    </div>
    <div class="mb-3">
        <label>Audio EN (.mp3)</label>
        <input asp-for="AudioEn" type="file" class="form-control" accept=".mp3,audio/mpeg" />
        <small class="muted">@Model.TenFileAudio_En</small>
    </div>
    <div class="mb-3">
        <label>Audio ZH (.mp3)</label>
        <input asp-for="AudioZh" type="file" class="form-control" accept=".mp3,audio/mpeg" />
        <small class="muted">@Model.TenFileAudio_Zh</small>
    </div>

    <button type="submit" class="vk-btn primary">Lưu thay đổi</button>
</form>
