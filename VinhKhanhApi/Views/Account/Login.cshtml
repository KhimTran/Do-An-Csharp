@model VinhKhanhApi.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="vk-form" style="max-width:520px;margin:40px auto;">
    <h2>Đăng nhập hệ thống</h2>
    <form method="post" asp-action="Login" asp-controller="Account">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />
        <div class="mb-3">
            <label>Tài khoản</label>
            <input asp-for="Username" class="form-control" />
        </div>
        <div class="mb-3">
            <label>Mật khẩu</label>
            <input asp-for="Password" class="form-control" type="password" />
        </div>
        <div asp-validation-summary="All" class="text-danger mb-2"></div>
        <button class="vk-btn primary" type="submit">Đăng nhập</button>
    </form>
</div>
